# Terraform working directories and state
**/.terraform/*
*.tfstate
*.tfstate.*
*.tfplan
*.tfplan.*
.terraform.tfstate.lock.info

# Environment-specific values and backend settings
*.tfvars
*.tfvars.json
backend.hcl

# Keep examples in Git
!*.tfvars.example
!backend.hcl.example

# Terraform crash logs and local CLI config
crash.log
crash.*.log
.terraformrc
terraform.rc

# Local override files
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Editors and OS files
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
